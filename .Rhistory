barplot(missing_count,main = "Missing Values Per Column", ylab = "count", col = "steelblue", las = 2)
hotel_bookings$children[is.na(hotel_bookings$children)] <- median(hotel_bookings$children, na.rm = TRUE)
hotel_bookings$adr[is.na(hotel_bookings$adr)] <-mean(hotel_bookings$adr, na.rm = TRUE)
hotel_bookings$country[is.na(hotel_bookings$country)] <- "Unknown"
